# Copy this file to .dev.vars and fill in your API keys for local development
# These are used by `npm run dev` (wrangler dev)

GROQ_API_KEY=
CEREBRAS_API_KEY=
GOOGLE_API_KEY=
OPENROUTER_API_KEY=
COHERE_API_KEY=

# Optional: set this to require an Authorization header on all requests
# FREELLM_API_KEY=
